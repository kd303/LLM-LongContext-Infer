   "source": [
    "import torch\n",
    "from PIL import Image\n",
    "import numpy as np\n",
    "from transformers import CLIPProcessor, CLIPModel\n",
    "\n",
    "# 1. Load the specific OpenAI Large Patch 14 model\n",
    "model_id = \"openai/clip-vit-large-patch14\"\n",
    "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "\n",
    "model = CLIPModel.from_pretrained(model_id).to(device)\n",
    "processor = CLIPProcessor.from_pretrained(model_id)\n",
    "\n",
    "print(f\"Model loaded on {device} successfully.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 37,
   "id": "611fb782",
   "metadata": {},
   "outputs": [],
   "source": [
    "import time\n",
    "\n",
    "def get_ms(start, end):\n",
    "    return (end - start) * 1000"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 41,
   "id": "dc3c5b3a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Zero-Shot Accuracy on 50 samples: 92.00%\n"
     ]
    }
   ],
   "source": [
    "pre_proc_times = []\n",
    "model_times = []\n",
    "post_proc_times = []\n",
    "\n",
    "# Create prompts\n",
    "candidate_queries = [f\"a photo of a {name}\" for name in class_names]\n",
    "\n",
    "# Run inference\n",
    "model.eval()\n",
    "correct_count = 0\n",
    "\n",
    "for i in range(len(subset_images)):\n",
    "    image = subset_images[i]\n",
    "    actual_label = class_names[subset_label_ids[i]]\n",
    "    \n",
    "    torch.cuda.synchronize() # Wait for GPU to be ready\n",
    "    t0 = time.perf_counter()\n",
    "    # Process inputs\n",
    "    inputs = processor(text=candidate_queries, images=image, return_tensors=\"pt\", padding=True).to(device)\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    t1 = time.perf_counter()\n",
    "    pre_proc_times.append(get_ms(t0, t1))\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        t2 = time.perf_counter()\n",
    "        outputs = model(**inputs)\n",
    "        torch.cuda.synchronize()\n",
    "        t3 = time.perf_counter()\n",
    "        model_times.append(get_ms(t2, t3))\n",
    "    t4 = time.perf_counter()\n",
    "    \n",
    "    # Calculate probabilities\n",
    "    probs = outputs.logits_per_image.softmax(dim=1)\n",
    "    predicted_id = probs.argmax().item()\n",
    "    predicted_label = class_names[predicted_id]\n",
    "    t5 = time.perf_counter()\n",
    "    post_proc_times.append(get_ms(t4, t5))\n",
    "    \n",
    "    if predicted_label == actual_label:\n",
    "        correct_count += 1\n",
    "\n",
    "print(f\"Zero-Shot Accuracy on 50 samples: {correct_count/50:.2%}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 42,
   "id": "ccaa6a87",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "--- Timing Results (Averages over 50 images) ---\n",
      "Preprocessing: 4.57 ms\n",
      "Model Forward: 25.57 ms\n",
      "Post-processing: 0.09 ms\n",
      "Total Latency: 30.23 ms\n"
     ]
    }
   ],
   "source": [
    "avg_pre = sum(pre_proc_times) / 50\n",
    "avg_model = sum(model_times) / 50\n",
    "avg_post = sum(post_proc_times) / 50\n",
    "\n",
    "print(f\"\\n--- Timing Results (Averages over 50 images) ---\")\n",
    "print(f\"Preprocessing: {avg_pre:.2f} ms\")\n",
    "print(f\"Model Forward: {avg_model:.2f} ms\")\n",
    "print(f\"Post-processing: {avg_post:.2f} ms\")\n",
    "print(f\"Total Latency: {avg_pre + avg_model + avg_post:.2f} ms\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "8b9fdebe",
   "metadata": {},
   "source": [
    "## Now lets how does the timing change when processing these images on GPUs"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 47,
   "id": "4e355079",
   "metadata": {},
   "outputs": [],
   "source": [
    "import torchvision.transforms as T\n",
    "\n",
    "mean = (0.48145466, 0.4578275, 0.40821073)\n",
    "std = (0.26862954, 0.26130258, 0.27577711)\n",
    "\n",
    "gpu_preprocess = T.Compose([\n",
    "    T.Resize((224, 224), interpolation=T.InterpolationMode.BICUBIC),\n",
    "    T.CenterCrop(224),\n",
    "    T.ConvertImageDtype(torch.float32),\n",
    "    T.Normalize(mean=mean, std=std)\n",
    "])\n",
    "\n",
    "\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 49,
   "id": "2b895c76",
   "metadata": {},
   "outputs": [],
   "source": [
    "torch.cuda.empty_cache()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 54,
   "id": "2c253b5b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "CPU Preprocessing (50 images): 24.81 ms\n",
      "GPU Preprocessing (50 images): 6.56 ms\n",
      "Speedup: 3.8x\n"
     ]
    }
   ],
   "source": [
    "def benchmark_preprocessing():\n",
    "    # --- Case A: Standard CLIPProcessor (CPU) ---\n",
    "    start_cpu = time.perf_counter()\n",
    "    _ = processor(images=subset_images, return_tensors=\"pt\")\n",
    "    cpu_time = (time.perf_counter() - start_cpu) * 1000\n",
    "\n",
    "    # --- Case B: Torchvision Transforms (GPU) ---\n",
    "    torch.cuda.synchronize()\n",
    "    start_gpu = time.perf_counter()\n",
    "    \n",
    "    # Preprocess all 50 images in one parallel GPU burst\n",
    "    with torch.no_grad():\n",
    "        raw_tensors = torch.stack([T.functional.to_tensor(img) for img in subset_images]).to(device)\n",
    "        gpu_processed_images = gpu_preprocess(raw_tensors)\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    gpu_time = (time.perf_counter() - start_gpu) * 1000\n",
    "\n",
    "    print(f\"CPU Preprocessing (50 images): {cpu_time:.2f} ms\")\n",
    "    print(f\"GPU Preprocessing (50 images): {gpu_time:.2f} ms\")\n",
    "    print(f\"Speedup: {cpu_time / gpu_time:.1f}x\")\n",
    "\n",
    "benchmark_preprocessing()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5b5b0900",
   "metadata": {},
   "outputs": [],
   "source": [
    "CPU Preprocessing (50 images): 29.47 ms\n",
    "GPU Preprocessing (50 images): 17.21 ms\n",
    "Speedup: 1.7x"
   ]
  }
