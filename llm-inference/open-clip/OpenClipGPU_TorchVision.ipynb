    "import torch\n",
    "import torchvision\n",
    "from torchvision import transforms\n",
    "from PIL import Image\n",
    "\n",
    "total_imag = 50\n",
    "# 1. Download and load the CIFAR-10 test set\n",
    "# It contains 10,000 images, we will take the first 50\n",
    "dataset = torchvision.datasets.CIFAR10(root='./data', train=False, download=True)\n",
    "\n",
    "# 2. Extract 50 images and their numeric labels\n",
    "subset_images = [dataset[i][0] for i in range(total_imag)]\n",
    "subset_label_ids = [dataset[i][1] for i in range(total_imag)]\n",
    "\n",
    "# 3. Define the human-readable class names (CIFAR-10 order is fixed)\n",
    "class_names = ['airplane', 'automobile', 'bird', 'cat', 'deer', 'dog', 'frog', 'horse', 'ship', 'truck']"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 50,
   "id": "5e931799",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "application/vnd.jupyter.widget-view+json": {
       "model_id": "dc99f56bb885456c92e36d942a4b6c0c",
       "version_major": 2,
       "version_minor": 0
      },
      "text/plain": [
       "Loading weights:   0%|          | 0/590 [00:00<?, ?it/s]"
      ]
     },
     "metadata": {},
